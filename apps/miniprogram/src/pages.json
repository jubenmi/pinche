{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uv-(.*)": "@/uni_modules/uv-ui-tools/components/uv-$1/uv-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "剧本迷·拼车"
      }
    },
    {
      "path": "pages/mine/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/admin/catalog",
      "style": {
        "navigationBarTitleText": "资料管理",
        "usingComponents": {
          "t-tabs": "/wxcomponents/tdesign-miniprogram/tabs/tabs",
          "t-tab-panel": "/wxcomponents/tdesign-miniprogram/tab-panel/tab-panel"
        }
      }
    },
    {
      "path": "pages/session/create",
      "style": {
        "navigationBarTitleText": "选择店家"
      }
    },
    {
      "path": "pages/session/script",
      "style": {
        "navigationBarTitleText": "选择剧本"
      }
    },
    {
      "path": "pages/session/role",
      "style": {
        "navigationBarTitleText": "选择角色"
      }
    },
    {
      "path": "pages/session/setup",
      "style": {
        "navigationBarTitleText": "开本设置"
      }
    },
    {
      "path": "pages/session/share",
      "style": {
        "navigationBarTitleText": "分享"
      }
    },
    {
      "path": "pages/session/detail",
      "style": {
        "navigationBarTitleText": "车详情"
      }
    },
    {
      "path": "pages/session/review",
      "style": {
        "navigationBarTitleText": "写记录"
      }
    },
    {
      "path": "pages/session/review-share",
      "style": {
        "navigationBarTitleText": "游后感"
      }
    },
    {
      "path": "pages/session/album",
      "style": {
        "navigationBarTitleText": "相册"
      }
    },
    {
      "path": "pages/session/albumPrivacy",
      "style": {
        "navigationBarTitleText": "相册隐私"
      }
    },
    {
      "path": "pages/session/manage",
      "style": {
        "navigationBarTitleText": "车头管理"
      }
    }
  ],
  "globalStyle": {
    "usingComponents": {
      "t-action-sheet": "/wxcomponents/tdesign-miniprogram/action-sheet/action-sheet",
      "t-button": "/wxcomponents/tdesign-miniprogram/button/button",
      "t-date-time-picker": "/wxcomponents/tdesign-miniprogram/date-time-picker/date-time-picker",
      "t-badge": "/wxcomponents/tdesign-miniprogram/badge/badge",
      "t-dialog": "/wxcomponents/tdesign-miniprogram/dialog/dialog",
      "t-empty": "/wxcomponents/tdesign-miniprogram/empty/empty",
      "t-icon": "/wxcomponents/tdesign-miniprogram/icon/icon",
      "t-image": "/wxcomponents/tdesign-miniprogram/image/image",
      "t-input": "/wxcomponents/tdesign-miniprogram/input/input",
      "t-notice-bar": "/wxcomponents/tdesign-miniprogram/notice-bar/notice-bar",
      "t-picker": "/wxcomponents/tdesign-miniprogram/picker/picker",
      "t-picker-item": "/wxcomponents/tdesign-miniprogram/picker-item/picker-item",
      "t-popup": "/wxcomponents/tdesign-miniprogram/popup/popup",
      "t-search": "/wxcomponents/tdesign-miniprogram/search/search",
      "t-segmented": "/wxcomponents/tdesign-miniprogram/segmented/segmented",
      "t-switch": "/wxcomponents/tdesign-miniprogram/switch/switch",
      "t-tag": "/wxcomponents/tdesign-miniprogram/tag/tag",
      "t-textarea": "/wxcomponents/tdesign-miniprogram/textarea/textarea",
      "t-toast": "/wxcomponents/tdesign-miniprogram/toast/toast"
    },
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "剧本迷·拼车",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f7f7f7"
  }
}
