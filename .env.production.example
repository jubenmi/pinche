NODE_ENV=production
PORT=3018
APP_BASE_URL=https://api.pinche.jubenmi.com

DATABASE_TARGET_LOCK=cloud
DATABASE_TARGET_LOCK_HOST=nj-cynosdbmysql-grp-9cgedjkh.sql.tencentcdb.com

MYSQL_HOST=nj-cynosdbmysql-grp-9cgedjkh.sql.tencentcdb.com
MYSQL_PORT=25909
MYSQL_DATABASE=pinche
MYSQL_USER=pinche
MYSQL_PASSWORD=replace-with-production-mysql-password

REDIS_ENABLED=true
REDIS_URL=
REDIS_HOST=10.206.16.15
REDIS_PORT=6379
REDIS_DB=3
REDIS_PASSWORD=

COS_ENABLED=true
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=pinche-app-1251022382
COS_REGION=ap-nanjing
COS_CI_CALLBACK_TOKEN=replace-with-cos-ci-callback-token
COS_DIRECT_MEDIA_URLS=false
COS_DIRECT_UPLOAD_REQUIRED=false
# D46 能力是启动时 provider 配置快照；生产预演不是动态 health。DB 开关仅在 provider 关闭并重启后决定 fallback。
# INTAKE_MODE 仅兼容保留，不再控制流量。
CONTENT_MODERATION_ENABLED=true
CONTENT_MODERATION_WECHAT_TEXT_ENABLED=false
CONTENT_MODERATION_TEXT_INTAKE_MODE=legacy
CONTENT_MODERATION_WECHAT_IMAGE_ENABLED=false
CONTENT_MODERATION_IMAGE_INTAKE_MODE=legacy
CONTENT_MODERATION_TENCENT_VIDEO_ENABLED=false
CONTENT_MODERATION_VIDEO_INTAKE_MODE=legacy
# D46 作者私有能力独立于上面的 D45 intake，默认不接收作者私有真实内容。
CONTENT_MODERATION_AUTHOR_PRIVATE_TEXT_ENABLED=false
CONTENT_MODERATION_AUTHOR_PRIVATE_TEXT_ACTIONS=
CONTENT_MODERATION_AUTHOR_PRIVATE_IMAGE_ENABLED=false
CONTENT_MODERATION_AUTHOR_PRIVATE_VIDEO_ENABLED=false
CONTENT_MODERATION_AUTHOR_PREVIEW_TTL_SECONDS=60
TENCENT_CI_VIDEO_REGION=ap-nanjing
TENCENT_CI_VIDEO_BIZ_TYPE=
TENCENT_CI_VIDEO_CALLBACK_URL=https://api.pinche.jubenmi.com/api/internal/content-moderation/tencent-video/callback
TENCENT_CI_VIDEO_CALLBACK_TOKEN=replace-with-at-least-32-random-characters
# 留空表示未处于轮换期；轮换时保留上一枚至少 32 位随机令牌，待旧任务回调完成后清空。
TENCENT_CI_VIDEO_CALLBACK_PREVIOUS_TOKEN=
CONTENT_MODERATION_RETRY_LIMIT=8
# Worker 使用固定轮询，单任务独立租约；网络超时必须短于租约。
CONTENT_MODERATION_RETRY_POLL_MS=30000
CONTENT_MODERATION_RETRY_BATCH_SIZE=25
CONTENT_MODERATION_RETRY_LEASE_MS=90000
# 队列超过该年龄会记录高优先级告警；孤儿扫描默认只报告，需确认 CAM List/Head/Delete 权限后再单独启用。
CONTENT_MODERATION_QUEUE_ALERT_AGE_SECONDS=900
CONTENT_MODERATION_ORPHAN_SCAN_ENABLED=false
CONTENT_MODERATION_ORPHAN_CLEANUP_ENABLED=false
CONTENT_MODERATION_ORPHAN_SCAN_POLL_MS=300000
CONTENT_MODERATION_ORPHAN_SCAN_BATCH_SIZE=100
CONTENT_MODERATION_ORPHAN_RETENTION_HOURS=48
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_ENABLED=false
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_CONFIRMATION=example-confirmation-value-not-for-real-use
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_OPERATOR_USER_ID=0
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_TEST_ADMIN_USER_ID=0
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_REFERENCE_HMAC_KEY=example-independent-hmac-key-not-for-real-use
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_IMAGE_FINGERPRINT=production-preflight-image-v1
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_VIDEO_FINGERPRINT=production-preflight-video-v1
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_RELEASE_FINGERPRINT=d45-production-controlled-preflight
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_CALLBACK_TIMEOUT_MS=900000
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_TIMEOUT_POLL_MS=60000
CONTENT_MODERATION_PRODUCTION_PREFLIGHT_TIMEOUT_BATCH_SIZE=10

WECHAT_MOCK_LOGIN=false
WECHAT_APP_ID=wx2675a606d3bd242c
WECHAT_APP_SECRET=replace-with-wechat-app-secret
WECHAT_CONTENT_SECURITY_EVENT_TOKEN=replace-with-wechat-content-security-event-token
WECHAT_CONTENT_SECURITY_EVENT_AES_KEY=replace-with-wechat-content-security-event-aes-key
WECHAT_SUBSCRIBE_MESSAGE_ENABLED=false
WECHAT_SUBSCRIBE_TEMPLATE_SIGNUP_CREATED=replace-with-signup-created-template-id
WECHAT_SUBSCRIBE_TEMPLATE_SIGNUP_REVIEWED=replace-with-signup-reviewed-template-id
WECHAT_SUBSCRIBE_SESSION_RESCHEDULED_TEMPLATE_ID=replace-with-session-rescheduled-template-id

# Mini Program build-time subscription template IDs
VITE_SUBSCRIBE_TEMPLATE_SESSION_RESCHEDULED=replace-with-session-rescheduled-template-id

SESSION_SECRET=replace-with-production-session-secret-at-least-32-chars
CONTACT_ENCRYPTION_KEY=replace-with-32-byte-production-contact-key
BOOTSTRAP_ADMIN_OPENIDS=replace-with-admin-openid
BOOTSTRAP_ADMIN_UNIONIDS=replace-with-admin-unionid
